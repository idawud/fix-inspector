<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 https://maven.apache.org/xsd/assembly-1.1.3.xsd">
  <id>plugin</id>
  <formats>
    <format>zip</format>
  </formats>
  <includeBaseDirectory>false</includeBaseDirectory>

  <dependencySets>
    <dependencySet>
      <!-- Place the project artifact and runtime dependencies into lib/ (IntelliJ plugin layout) -->
      <outputDirectory>lib</outputDirectory>
      <useProjectArtifact>true</useProjectArtifact>
      <unpack>false</unpack>
      <scope>runtime</scope>
    </dependencySet>
  </dependencySets>

  <!-- Ensure plugin.xml is available at the ZIP root (IntelliJ installer requires plugin descriptor accessible in the distribution). -->
  <fileSets>
    <fileSet>
      <directory>${project.build.outputDirectory}</directory>
      <outputDirectory>/</outputDirectory>
      <includes>
        <include>META-INF/plugin.xml</include>
      </includes>
    </fileSet>
  </fileSets>

  <!-- If you ever need plugin.xml at the ZIP root (not required because it is inside the plugin JAR),
       you can uncomment and adjust the following fileSet. -->
  <!--
  <fileSets>
    <fileSet>
      <directory>${project.build.outputDirectory}</directory>
      <outputDirectory>/</outputDirectory>
      <includes>
        <include>META-INF/plugin.xml</include>
      </includes>
    </fileSet>
  </fileSets>
  -->
</assembly>

